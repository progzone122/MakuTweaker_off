<Page x:Class="MakuTweakerNew.ContextMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MakuTweakerNew"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" d:DesignWidth="704.04" d:DesignHeight="712"
      Title="Context Menu">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="label" HorizontalAlignment="Left" Margin="24,11,0,0" TextWrapping="Wrap" Text="Context Menu" VerticalAlignment="Top" FontSize="32" FontFamily="Segoe UI Semibold"/>

                <ui:ToggleSwitch Header="Enable Old Context Menu" Margin="24,14,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t15" Toggled="t15_Toggled"/>
                <ui:ToggleSwitch Header="Remove Context Menu Delay" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t1" Toggled="t1_Toggled"/>
                <ui:ToggleSwitch Header="Open in Terminal" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t3" Toggled="t3_Toggled"/>

                <ui:ToggleSwitch Header="Share" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t5" Toggled="t5_Toggled"/>
                <ui:ToggleSwitch Header="Restore previous versions" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t6" Toggled="t6_Toggled"/>
                <ui:ToggleSwitch Header="Send to" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t8" Toggled="t8_Toggled"/>

                <ui:ToggleSwitch Header="Copy as path" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t10" Toggled="t10_Toggled"/>
                <ui:ToggleSwitch Header="Pin to Start menu" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t11" Toggled="t11_Toggled"/>
                <ui:ToggleSwitch Header="Pin to Taskbar" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t12" Toggled="t12_Toggled"/>
                <ui:ToggleSwitch Header="Open in new tab" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t13" Toggled="t13_Toggled"/>
                <ui:ToggleSwitch Header="NVIDIA Control Panel" Margin="24,8,0,0" VerticalAlignment="Top" FontSize="16"  x:Name="t14" Height="65" Toggled="t14_Toggled"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
