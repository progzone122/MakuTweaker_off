<ui:ContentDialog
    x:Class="MakuTweakerNew.HidePart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    Title="MakuTweaker"
    PrimaryButtonText="Close"
    CloseButtonText="Done"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    CloseButtonClick="ContentDialog_CloseButtonClick"
    DefaultButton="Close">

    <StackPanel x:Name="stp" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <TextBlock x:Name="textBlock" TextWrapping="Wrap" MaxWidth="500" />
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Height="269" MaxWidth="500">
            <Grid x:Name="checkboxpanel" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Row="0" Grid.Column="0" Margin="10,10,0,0" x:Name="a" Content="A:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="1" Grid.Column="0" Margin="10,0,0,0" x:Name="d" Content="D:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="2" Grid.Column="0" Margin="10,0,0,0" x:Name="e" Content="E:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="3" Grid.Column="0" Margin="10,0,0,0" x:Name="f" Content="F:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="4" Grid.Column="0" Margin="10,0,0,0" x:Name="g" Content="G:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="5" Grid.Column="0" Margin="10,0,0,0" x:Name="h" Content="H:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="6" Grid.Column="0" Margin="10,0,0,0" x:Name="i" Content="I:" HorizontalAlignment="Left"/>
                <CheckBox Grid.Row="7" Grid.Column="0" Margin="10,0,0,0" x:Name="j" Content="J:" HorizontalAlignment="Left"/>

                <CheckBox Grid.Row="0" Grid.Column="1" Margin="10,10,0,0" x:Name="k" Content="K:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="1" Grid.Column="1" Margin="10,0,0,0" x:Name="l" Content="L:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="2" Grid.Column="1" Margin="10,0,0,0" x:Name="m" Content="M:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="3" Grid.Column="1" Margin="10,0,0,0" x:Name="n" Content="N:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="4" Grid.Column="1" Margin="10,0,0,0" x:Name="o" Content="O:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="5" Grid.Column="1" Margin="10,0,0,0" x:Name="p" Content="P:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="6" Grid.Column="1" Margin="10,0,0,0" x:Name="q" Content="Q:" HorizontalAlignment="Center"/>
                <CheckBox Grid.Row="7" Grid.Column="1" Margin="10,0,0,0" x:Name="r" Content="R:" HorizontalAlignment="Center"/>

                <CheckBox Grid.Row="0" Grid.Column="2" Margin="10,10,0,0" x:Name="s" Content="S:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="1" Grid.Column="2" Margin="10,0,0,0" x:Name="t" Content="T:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="2" Grid.Column="2" Margin="10,0,0,0" x:Name="u" Content="U:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="3" Grid.Column="2" Margin="10,0,0,0" x:Name="v" Content="V:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="4" Grid.Column="2" Margin="10,0,0,0" x:Name="w" Content="W:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="5" Grid.Column="2" Margin="10,0,0,0" x:Name="x" Content="X:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="6" Grid.Column="2" Margin="10,0,0,0" x:Name="y" Content="Y:" HorizontalAlignment="Right"/>
                <CheckBox Grid.Row="7" Grid.Column="2" Margin="10,0,0,0" x:Name="z" Content="Z:" HorizontalAlignment="Right"/>
            </Grid>
        </ScrollViewer>
    </StackPanel>
</ui:ContentDialog>
