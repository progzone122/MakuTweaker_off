<Page x:Class="MakuTweakerNew.Personalization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MakuTweakerNew"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" 
      d:DesignHeight="702" d:DesignWidth="704.04"
      Title="Personalization">

    <Grid>
        <ScrollViewer>
            <StackPanel>
                <TextBlock x:Name="label" HorizontalAlignment="Left" Margin="24,11,0,0" TextWrapping="Wrap" Text="Personalization" VerticalAlignment="Top" FontSize="32" FontFamily="Segoe UI Semibold"/>
                <TextBlock x:Name="defaultnamelabel" HorizontalAlignment="Left" Margin="24,14,0,0" TextWrapping="Wrap" Text="Default Name for New Files and New Folders" VerticalAlignment="Top" FontSize="16"/>
                <controls:TextBox x:Name="newname" Margin="24,5,424,0" MaxLength="40" Watermark="New File" Height="31" VerticalAlignment="Top"/>
                <controls:Button x:Name="apN" Margin="0,-35,310,0" Content="Apply" Height="36" VerticalAlignment="Top" HorizontalAlignment="Right" Width="106" Click="apN_Click"/>
                <controls:Button x:Name="stN" Margin="0,-36,194,0" Content="Standard" VerticalAlignment="Top" Height="36" HorizontalAlignment="Right" Width="107" Click="stN_Click" />
                <TextBlock x:Name="colorlabel" HorizontalAlignment="Left" Margin="24,9,0,0" TextWrapping="Wrap" Text="Change Selection Colors" VerticalAlignment="Top" FontSize="16"/>
                <ComboBox x:Name="color" Padding="10,0,0,0" Margin="24,5,0,0" FontSize="14" MinWidth="177" MaxWidth="177" HorizontalAlignment="Left" Width="177" Height="25" VerticalAlignment="Top">
                    <ComboBoxItem x:Name="c1" Content="Standard"/>
                    <ComboBoxItem x:Name="c2" Content="Cyan"/>
                    <ComboBoxItem x:Name="c3" Content="Purple"/>
                    <ComboBoxItem x:Name="c4" Content="Green"/>
                    <ComboBoxItem x:Name="c5" Content="Orange"/>
                    <ComboBoxItem x:Name="c6" Content="Red"/>
                    <ComboBoxItem x:Name="c7" Content="Blue"/>
                    <ComboBoxItem x:Name="c8" Content="Black"/>
                </ComboBox>
                <controls:Button x:Name="apC" Margin="210,-30,0,0" Content="Apply" Height="30" VerticalAlignment="Top" HorizontalAlignment="Left" Width="106" Click="apC_Click"/>
                <ui:ToggleSwitch x:Name="endtask" Header="Enable End Task in Taskbar" Margin="24,11,0,0" VerticalAlignment="Top" FontSize="16" Toggled="endtask_Toggled"/>
                <ui:ToggleSwitch x:Name="smallwindows" Header="Small Window Buttons" Margin="24,7,0,0" VerticalAlignment="Top" FontSize="16" Toggled="smallwindows_Toggled"/>
                <ui:ToggleSwitch x:Name="blur" Header="Disable Blur on The Lock Screen" Margin="24,7,0,0" VerticalAlignment="Top" FontSize="16" Toggled="blur_Toggled"/>
                <ui:ToggleSwitch x:Name="transparency"  Header="Disable Transparency" Margin="24,7,0,0" VerticalAlignment="Top" FontSize="16" Toggled="transparency_Toggled"/>
                <ui:ToggleSwitch x:Name="darktheme" Header="Enable Dark theme" Margin="24,7,0,0" VerticalAlignment="Top" FontSize="16" Toggled="darktheme_Toggled"/>

                <StackPanel Orientation="Horizontal" Margin="24,10,0,0">
                    <ui:ToggleSwitch x:Name="verbose" Header="Verbose" VerticalAlignment="Top" FontSize="16" Toggled="verbose_Toggled"/>
                    <controls:Button Content="?" Width="18" Height="18" Margin="8,-29,0,0" FontSize="14" Padding="0" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                        <controls:Button.ToolTip>
                            <ToolTip MaxWidth="500" x:Name="sys_tooltip_verbose"/>
                        </controls:Button.ToolTip>
                    </controls:Button>
                </StackPanel>
                
                <ui:ToggleSwitch x:Name="disablelogo" Header="Disable Windows Logo in Bootloader" Margin="24,7,0,0" VerticalAlignment="Top" FontSize="16" Toggled="disablelogo_Toggled"/>
                <ui:ToggleSwitch x:Name="disableanim" Header="Disable Animation in Bootloader" Margin="24,7,0,0" VerticalAlignment="Top" FontSize="16" Toggled="disableanim_Toggled"/>
                <Rectangle HorizontalAlignment="Left" Height="17" Margin="3,0,0,0" VerticalAlignment="Top" Width="67"/>
            </StackPanel>

        </ScrollViewer>
        
    </Grid>
</Page>
