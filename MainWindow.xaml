<controls:MicaWindow x:Class="MakuTweakerNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MakuTweakerNew"
        xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d" ui:ThemeManager.RequestedTheme="Default"
        Title="MakuTweaker" 
        Height="675" MinHeight="675" MaxHeight="675"
        Width="1062" MinWidth="1062" MaxWidth="1062"
        SystemBackdropType="Tabbed" WindowStartupLocation="CenterScreen" 
        ResizeMode="CanMinimize"
        UseLayoutRounding="True"
        Loaded="MicaWindow_Loaded"
        FocusVisualStyle="{x:Null}"
        Focusable="False"
        Topmost="False" Icon="/makut.png" Foreground="White">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="0" 
                      CaptionHeight="32" 
                      CornerRadius="0" 
                      GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>

    <Grid>
        <TextBlock x:Name="status" FontSize="14" VerticalAlignment="Bottom" Margin="20,0,0,12" Grid.ColumnSpan="3"/>
        <ui:SplitView IsTabStop="False" KeyboardNavigation.TabNavigation="None" PaneBackground="{x:Null}" IsPaneOpen="True" CompactPaneLength="48" DisplayMode="Inline" TabIndex="0" Grid.ColumnSpan="3">
            <ui:SplitView.Pane>
                <Grid>
                    <TextBlock Text="MakuTweaker" FontSize="36" FontFamily="Segoe UI Semibold" HorizontalAlignment="Center" Grid.Row="1" Margin="0,10,0,0"/>
                    <ui:ListView x:Name="Category" Padding="0,70,0,0" SelectionChanged="ListView_SelectionChanged" Margin="0,0,0,0" IsMultiSelectCheckBoxEnabled="False">
                        <ui:ListViewItem x:Name="c1" Content="Explorer and Desktop" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c2" Content="Start Menu and Taskbar" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c3" Content="Windows Update" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c4" Content="Remove UWP Apps" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c5" Content="Quick Windows Setup" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c6" Content="Windows Activation" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c7" Content="Context Menu" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c8" Content="System and Recovery" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c9" Content="Miscellaneous" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c10" Content="Personalization" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c11" Content="Shutdown Timer" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c12" Content="Process Management" FontSize="18" HorizontalContentAlignment="Center"/>
                        <ui:ListViewItem x:Name="c13" Content="PC Information" FontSize="18" HorizontalContentAlignment="Center"/>
                    </ui:ListView>
                </Grid>
            </ui:SplitView.Pane>
            <ui:Frame x:Name="MainFrame" Navigated="MainFrame_Navigated" ScrollViewer.HorizontalScrollBarVisibility="Visible" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="603" VerticalAlignment="Top"/>
        </ui:SplitView>
        <Rectangle x:Name="Separator" Margin="0,563,0,0" Opacity="0.15" Fill="White" Stroke="White" Height="1" Width="1061.8"/>
        <ui:CommandBar x:Name="ABCB" DefaultLabelPosition="Right" Background="#00E6E6E6" Margin="203,0,0,0" VerticalAlignment="Bottom">
            <ui:AppBarButton x:Name="rexplorer" Icon="Refresh" Label="Restart Explorer" Click="rexplorer_Click"/>
            <ui:AppBarButton x:Name="settingsButton" Icon="Setting" Label="Settings / About" Click="settingsButton_Click"/>
        </ui:CommandBar>
    </Grid>
</controls:MicaWindow>